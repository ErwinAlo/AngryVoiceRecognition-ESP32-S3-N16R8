// Contador de iteraciones para impresión 
int i = 0;

// --- DEFINICIÓN DE PINES ---
#define BUZZER_PIN 18
#define MOSI_PIN   13
#define SCK_PIN    14
#define CS_PIN     10
#define NUM_MAT    1 

